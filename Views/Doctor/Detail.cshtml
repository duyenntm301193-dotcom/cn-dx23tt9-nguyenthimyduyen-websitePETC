@model dynamic

<div class="container mt-4">

    <h2>@Model.Name</h2>

    <img src="@Model.Image" class="img-fluid mb-3" style="max-height:300px;" />

    <p><strong>Chuyên môn:</strong> @Model.Speciality</p>

    <p><strong>Kinh nghiệm:</strong> @Model.Experience năm</p>

    <p>@Model.Description</p>

    <a href="/Appointment" class="btn btn-primary">
        Đặt lịch khám
    </a>

</div>