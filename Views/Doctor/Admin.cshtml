@model List<dynamic>

<div class="container mt-4">

    <h2>Quản lý bác sĩ</h2>

    <a href="/Doctor/Create" class="btn btn-primary mb-3">
        + Thêm bác sĩ
    </a>

    <table class="table table-bordered text-center">

        <tr>
            <th>Tên</th>
            <th>Chuyên môn</th>
            <th>Năm kinh nghiệm</th>
            <th>Mô tả</th>
            <th>Hình bác sĩ</th>
            <th>Hình bác sĩ</th>
            <th>Chỉnh sửa</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Speciality</td>
                <td>@item.Experience</td>
                <td>@item.Description</td>
                <td>@item.ImageUrl</td>
                <td>
                    <img src="@item.ImageUrl" style="width:80px;" />
                </td>
                <td>
                    <a asp-controller="Doctor" asp-action="Edit" asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-controller="Doctor" asp-action="Delete" asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }

    </table>

</div>