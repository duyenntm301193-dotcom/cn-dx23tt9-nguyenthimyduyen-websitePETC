<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PETC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PETC.styles.css" asp-append-version="true" />
    <style>
        body {
        padding-top: 80px;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"> 🐾 PETC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <!--  USER -->
                        @if (Context.Session.GetString("Role") != "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                    Trang chủ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Service" asp-action="Index">
                                    Dịch vụ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Doctor" asp-action="Index">
                                    Bác sĩ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Appointment" asp-action="Index">
                                    Đặt lịch
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Post">Tin tức & chăm sóc thú cưng</a>
                            </li>
                        }

                        <!-- ADMIN -->
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Appointment/Admin">
                                    Quản lý lịch
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Service/Admin">Quản lý dịch vụ</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Doctor/Admin">Quản lý bác sĩ</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Post/Admin">Quản lý tin tức</a>
                            </li>
                        }
                        


                        <!-- LOGIN / USER INFO -->
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-primary fw-bold">
                                    Xin chào, @Context.Session.GetString("UserName")
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Logout">Đăng xuất</a>
                            </li>

                            <!--  CHỈ USER MỚI THẤY -->
                            @if (Context.Session.GetString("Role") != "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/Pet">Thú cưng của tôi</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/Appointment/MyAppointments">Lịch của tôi</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Login">Đăng nhập</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" href="/Auth/Register">Đăng ký</a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PETC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
