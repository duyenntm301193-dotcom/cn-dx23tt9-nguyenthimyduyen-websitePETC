@model dynamic

<div class="container mt-4">

    <div class="row">

        <!-- ẢNH -->
        <div class="col-md-6">
            <img src="@Model.Image" class="img-fluid rounded shadow-sm" />
        </div>

        <!-- THÔNG TIN -->
        <div class="col-md-6">

            <h2>@Model.Name</h2>

            <p class="text-muted">@Model.Description</p>

            <h4 class="text-danger">
                @String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0}", Model.Price) VNĐ
            </h4>

            <br />

            <a href="/Appointment?serviceId=@Model.Id" class="btn btn-primary btn-lg">
                Đặt lịch ngay
            </a>

        </div>

    </div>

</div>