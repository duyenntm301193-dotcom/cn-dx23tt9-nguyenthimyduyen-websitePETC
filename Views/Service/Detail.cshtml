@{
    ViewData["Title"] = "Chi tiết dịch vụ";
}

<div class="container mt-5">

    <div class="row">

        <!-- ẢNH -->
        <div class="col-md-4 text-center">
            <img src="@ViewBag.Image" class="img-fluid rounded shadow">
        </div>

        <!-- THÔNG TIN -->
        <div class="col-md-8">
            <h2 class="text-primary">@ViewBag.Name</h2>

            <p class="mt-3">@ViewBag.Description</p>

            <h5 class="text-danger mt-3">Giá: @ViewBag.Price</h5>

            <div class="mt-4">
                <a asp-controller="Appointment" asp-action="Index"
                   class="btn btn-success me-2">
                    Đặt lịch ngay
                </a>

                <a asp-controller="Service" asp-action="Index"
                   class="btn btn-secondary">
                    Quay lại danh sách
                </a>
            </div>
        </div>

    </div>

</div>