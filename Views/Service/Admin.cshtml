@model List<dynamic>

<div class="container mt-4">

    <h2>Quản lý dịch vụ</h2>

    <a asp-controller="Service" asp-action="Create" class="btn btn-primary mb-3">
        + Thêm dịch vụ
    </a>

    <table class="table table-bordered text-center">

        <thead>
            <tr>
                <th>Tên</th>
                <th>Giá</th>
                <th>Mô tả</th>
               
                <th>Ảnh</th>
                <th>Chỉnh sửa</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>@item.Description</td>
                    <td>@item.ImageUrl</td>
                    <td>
                        <img src="@item.ImageUrl" style="width:80px;" />
                    </td>
                    <td>
                        <!-- SỬA -->
                        <a asp-controller="Service" asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            Sửa
                        </a>

                        <!-- XÓA -->
                        <a asp-controller="Service" asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            Xóa

                        </a>
                    </td>
                
                </tr>
            }
        </tbody>

    </table>

</div>