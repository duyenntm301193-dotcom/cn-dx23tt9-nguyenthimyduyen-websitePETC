@model List<dynamic>

<div class="container mt-4">

    <h2>Quản lý bài viết</h2>

    <a href="/Post/Create" class="btn btn-primary mb-3">+ Thêm bài</a>

    <table class="table table-bordered">
        <tr>
            <th>Tiêu đề</th>
            <th>Nội dung</th>
            <th>Ảnh</th>
            <th>Hành động</th>

        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td style="max-width:400px; text-align:left;">
                    @item.Content
                </td>
               
                <td>
                    <img src="@item.ImageUrl" style="width:80px;" />
                </td>

                <td>
                    <a href="/Post/Detail/@item.Id" class="btn btn-info btn-sm">Xem</a>

                    <a href="/Post/Edit/@item.Id" class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a href="/Post/Delete/@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </table>

</div>