@model List<dynamic>

<div class="container mt-4">

    <h2 class="mb-4">Tin tức & chăm sóc thú cưng</h2>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <!-- CLICK TO DETAIL -->
                <a href="/Post/Detail/@item.Id" style="text-decoration:none; color:black;">

                    <div class="card h-100 shadow-sm">

                        <!-- IMAGE -->
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl"
                                 class="card-img-top"
                                 style="height:200px; object-fit:cover;" />
                        }
                        else
                        {
                            <img src="https://via.placeholder.com/300x200?text=No+Image"
                                 class="card-img-top"
                                 style="height:200px; object-fit:cover;" />
                        }

                        <!-- BODY -->
                        <div class="card-body">

                            <h5 class="card-title">@item.Title</h5>

                            <p class="card-text">
                                @item.Content.Substring(0, Math.Min(100, item.Content.Length))...
                            </p>

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-white border-0">
                            <span class="text-primary">Xem chi tiết →</span>
                        </div>

                    </div>

                </a>

            </div>
        }

    </div>

</div>