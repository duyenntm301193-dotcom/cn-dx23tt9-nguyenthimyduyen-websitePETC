@model dynamic

<div class="container mt-4">

    <h2>Chỉnh sửa thông tin phòng khám</h2>

    <form method="post">

        <input type="hidden" name="id" value="@Model.Id" />

        <input name="name" value="@Model.Name" class="form-control mb-2" placeholder="Tên" />

        <textarea name="description" class="form-control mb-2">@Model.Description</textarea>

        <input name="address" value="@Model.Address" class="form-control mb-2" placeholder="Địa chỉ" />

        <input name="phone" value="@Model.Phone" class="form-control mb-2" placeholder="SĐT" />

        <input name="email" value="@Model.Email" class="form-control mb-2" placeholder="Email" />

        <input name="imageUrl" value="@Model.ImageUrl" class="form-control mb-2" placeholder="Link ảnh" />

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" style="max-width:200px; margin-bottom:10px;" />
        }

        <button class="btn btn-primary">Cập nhật</button>

    </form>

</div>