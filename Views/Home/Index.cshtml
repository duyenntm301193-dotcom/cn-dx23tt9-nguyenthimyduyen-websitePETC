@if (ViewBag.Clinic != null)
{
    <div class="container mt-4">

        <h2>@ViewBag.Clinic.Name</h2>

        <img src="@ViewBag.Clinic.ImageUrl"
             style="width:100%; max-height:300px; object-fit:cover;" />

        <p class="mt-3">@ViewBag.Clinic.Description</p>

        <p><b>📍 Địa chỉ:</b> @ViewBag.Clinic.Address</p>
        <p><b>📞 Điện thoại:</b> @ViewBag.Clinic.Phone</p>
        <p><b>📧 Email:</b> @ViewBag.Clinic.Email</p>

        <hr />
    </div>@if (Context.Session.GetString("Role") == "Admin")
    {
        <div class="mb-3">
            <a href="/Home/Edit" class="btn btn-warning">
                ⚙️ Cập nhật thông tin phòng khám
            </a>
        </div>
    }
}
<h2 class="mb-4">Dịch vụ nổi bật</h2>

<div class="row">
    @foreach (var s in ViewBag.Services)
    {
        <div class="col-md-4 mb-3">

            <a href="/Service/Detail/@s.Id" style="text-decoration: none; color: inherit;">

                <div class="card p-3 h-100 shadow-sm hover-card">

                    <h5>@s.Name</h5>
                    <p>@s.Description</p>
                </div>

            </a>
        </div>
    }
</div>

<hr />

<h2 class="mb-4">Đội ngũ bác sĩ</h2>

<div class="row">
    @foreach (var d in ViewBag.Doctors)
    {
        <div class="col-md-4 mb-3">

            <a href="/Doctor/Detail/@d.Id" style="text-decoration: none; color: inherit;">

                <div class="card p-3 h-100 shadow-sm hover-card">

                    <h5>@d.Name</h5>
                    <p>@d.Speciality</p>

                </div>

            </a>

        </div>
    }
</div>
